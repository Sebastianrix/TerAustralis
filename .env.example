# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=your_very_long_random_secret_key_at_least_32_characters_long
JWT_ISSUER=https://api.teraustralis.io
JWT_AUDIENCE=https://teraustralis.io

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to register: https://api.teraustralis.io/signin-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: https://api.teraustralis.io/signin-github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── URLs ──────────────────────────────────────────────────────────────────────
# React frontend origin (for CORS) and OAuth post-login redirect base
FRONTEND_URL=http://localhost
